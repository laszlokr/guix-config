# =============================================================================
# Docker Compose — environment template
#
# Copy this file to docker/.env and fill in every value before starting any
# stack.  The .env file is listed in .gitignore and must never be committed.
#
# Generate strong passwords with:  openssl rand -base64 32
# =============================================================================

# --- PostgreSQL (Odoo) -------------------------------------------------------

POSTGRES_USER=odoo
# TODO: set a strong random password
POSTGRES_PASSWORD=

POSTGRES_DB=odoo

# --- PostgreSQL (Nextcloud) --------------------------------------------------

NEXTCLOUD_POSTGRES_USER=nextcloud
# TODO: set a strong random password (different from Odoo's)
NEXTCLOUD_POSTGRES_PASSWORD=

NEXTCLOUD_POSTGRES_DB=nextcloud

# --- Odoo --------------------------------------------------------------------

# Master password for /web/database/manager — set after first start via UI,
# or place the hash here (generate: python3 -c "from passlib.hash import pbkdf2_sha512; print(pbkdf2_sha512.hash('yourpass'))")
ODOO_ADMIN_PASSWD=

# --- Nextcloud ---------------------------------------------------------------

NEXTCLOUD_ADMIN_USER=admin
# TODO: set a strong password
NEXTCLOUD_ADMIN_PASSWORD=

# --- Redis (Nextcloud session cache) -----------------------------------------
# Optional: leave empty to run Redis without authentication (fine on an
# internal Docker network).  If set, also set REDIS_HOST_PASSWORD in
# nextcloud/compose.yml.
REDIS_PASSWORD=

# --- n8n ---------------------------------------------------------------------

N8N_BASIC_AUTH_USER=admin
# TODO: set a strong password
N8N_BASIC_AUTH_PASSWORD=

# Full public URL used for webhooks, including trailing slash.
# Example: https://box.example.com/n8n/
WEBHOOK_URL=

# --- Gotify ------------------------------------------------------------------

# TODO: set a strong password
GOTIFY_DEFAULTUSER_PASS=
